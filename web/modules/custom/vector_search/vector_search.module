<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_insert().
 */
function vector_search_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }
  _ai_vector_send_to_python($entity);
  _ai_vector_generate_seo($entity);
}

/**
 * Implements hook_entity_update().
 */
function vector_search_entity_update(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }
  _ai_vector_send_to_python($entity);
  _ai_vector_generate_seo($entity);
}

/**
 * Send node to Python API for vector storage.
 * Your original function — unchanged.
 */
function _ai_vector_send_to_python(EntityInterface $entity) {
  if (!$entity->hasField('body')) {
    return;
  }

  try {
    $client = \Drupal::httpClient();
    $response = $client->post('http://vector-api:8000/nodes/store', [
      'headers' => [
        'Content-Type' => 'application/json',
        'Accept'       => 'application/json',
      ],
      'json' => [
        'node_id' => (int) $entity->id(),
        'title'   => (string) $entity->label(),
        'content' => 'test',
      ],
      'timeout'     => 20,
      'http_errors' => FALSE,  // 👈 VERY IMPORTANT
    ]);

    $body = $response->getBody()->getContents();
    \Drupal::logger('vector_api')->notice('Response: @res', ['@res' => $body]);
  }
  catch (\Exception $e) {
    \Drupal::logger('vector_api')->error($e->getMessage());
  }
}

/**
 * Generate SEO tags via Python API and save back to node fields.
 * New function — only runs for article nodes with body field.
 */
function _ai_vector_generate_seo(EntityInterface $entity) {

  // Only process article nodes
  if ($entity->bundle() !== 'article') {
    return;
  }

  // Need body field to generate SEO
  if (!$entity->hasField('body') || $entity->get('body')->isEmpty()) {
    return;
  }

  // Get plain text content — strip_tags removes HTML
  $content = strip_tags($entity->get('body')->value);
  $title   = (string) $entity->label();
  $node_id = (int) $entity->id();

  if (empty($content)) {
    return;
  }

  try {
    $client = \Drupal::httpClient();

    $response = $client->post('http://vector-api:8000/seo/generate', [
      'headers' => [
        'Content-Type' => 'application/json',
        'Accept'       => 'application/json',
      ],
      'json' => [
        'node_id' => $node_id,
        'title'   => $title,
        'content' => $content,
      ],
      'timeout'     => 30,     // SEO generation takes a few seconds
      'http_errors' => FALSE,  // don't throw exception on 4xx/5xx
    ]);

    // Check HTTP status
    $status = $response->getStatusCode();
    if ($status !== 200) {
      \Drupal::logger('vector_api')->error(
        'SEO generation failed for node @id with status @status',
        ['@id' => $node_id, '@status' => $status]
      );
      return;
    }

    $seo = json_decode($response->getBody()->getContents(), TRUE);

    if (empty($seo)) {
      return;
    }

    // ── Save SEO fields back to node ─────────────────────────
    // Make sure these 3 fields exist on your article content type
    // Admin → Structure → Content types → Article → Manage fields

    $changed = FALSE;

    if ($entity->hasField('field_seo_title') && !empty($seo['meta_title'])) {
      $entity->set('field_seo_title', $seo['meta_title']);
      $changed = TRUE;
    }

    if ($entity->hasField('field_seo_description') && !empty($seo['meta_desc'])) {
      $entity->set('field_seo_description', $seo['meta_desc']);
      $changed = TRUE;
    }

    if ($entity->hasField('field_seo_keywords') && !empty($seo['keywords'])) {
      $entity->set('field_seo_keywords', $seo['keywords']);
      $changed = TRUE;
    }

    // Save only if something changed — avoids unnecessary DB writes
    if ($changed) {
      // setSyncing(TRUE) prevents hook_entity_update from firing again
      // This avoids an infinite loop: save → hook → save → hook ...
      $entity->setSyncing(TRUE);
      $entity->save();
      $entity->setSyncing(FALSE);

      \Drupal::logger('vector_api')->notice(
        'SEO tags saved for node @id — title: @title',
        ['@id' => $node_id, '@title' => $seo['meta_title']]
      );
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('vector_api')->error(
      'SEO generation exception for node @id: @error',
      ['@id' => $node_id, '@error' => $e->getMessage()]
    );
  }
}